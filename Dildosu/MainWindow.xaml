<Window x:Class="Dildosu.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:local="clr-namespace:Dildosu" xmlns:sys="clr-namespace:System;assembly=netstandard"
        Closing="MainWindow_Closing"  
        mc:Ignorable="d"
        Title="Dildosu" Height="800" Width="1200" Icon="/dildo.png"
        ui:WindowHelper.UseModernWindowStyle="True">
    <Window.Resources>
        <sys:Int32 x:Key="c300Num">0</sys:Int32>
        <sys:Int32 x:Key="c100Num">0</sys:Int32>
        <sys:Int32 x:Key="c50Num">0</sys:Int32>
        <sys:Int32 x:Key="missNum">0</sys:Int32>
        <sys:Int32 x:Key="comboNum">0</sys:Int32>
        <sys:Int32 x:Key="sbNum">0</sys:Int32>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="61*"/>
            <RowDefinition Height="739*"/>
        </Grid.RowDefinitions>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FF191718"/>
                <GradientStop Color="#FF330719" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Label Content="dick your circles" HorizontalAlignment="Center" Margin="0,659,0,0" VerticalAlignment="Top" Width="656" Height="55" Foreground="#2FF792DC" FontFamily="Photonica" FontSize="48" RenderTransformOrigin="0.5,0.5" Grid.Row="1"/>
        <GroupBox HorizontalAlignment="Left" Height="484" Header="Settings" Margin="596,10,0,0" VerticalAlignment="Top" Width="468" Foreground="White" Background="#7F000000" Grid.Row="1">
            <Grid>
                <Label Content="Hits:" HorizontalAlignment="Left" Margin="11,40,0,0" VerticalAlignment="Top" Foreground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" Width="44"/>
                <Label Content="100s:" HorizontalAlignment="Left" Margin="11,71,0,0" VerticalAlignment="Top" Foreground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" Height="28" Width="44"/>
                <Label Content="50s:" HorizontalAlignment="Left" Margin="11,99,0,0" VerticalAlignment="Top" Foreground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" Height="28" Width="44"/>
                <Label Content="Misses:" HorizontalAlignment="Left" Margin="11,131,0,0" VerticalAlignment="Top" Foreground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" Height="28"/>
                <Label Content="SBs:" HorizontalAlignment="Left" Margin="11,163,0,0" VerticalAlignment="Top" Foreground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" Height="28" Width="41"/>
                <Label Content="Combo:" HorizontalAlignment="Left" Margin="11,239,0,0" VerticalAlignment="Top" Foreground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" Height="28" Width="53"/>


                <Label x:Name="hitCountLabel" Content="0" HorizontalAlignment="Left" Margin="71,40,0,0" VerticalAlignment="Top" Foreground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" Height="28" Width="41"/>
                <Label x:Name="hundredCountLabel" Content="0" HorizontalAlignment="Left" Margin="71,71,0,0" VerticalAlignment="Top" Foreground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" Height="28" Width="41"/>
                <Label x:Name="fiftyCountLabel" Content="0" HorizontalAlignment="Left" Margin="71,99,0,0" VerticalAlignment="Top" Foreground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" Height="28" Width="41"/>
                <Label x:Name="missCountLabel" Content="0" HorizontalAlignment="Left" Margin="71,131,0,0" VerticalAlignment="Top" Foreground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" Height="28" Width="41"/>
                <Label x:Name="sbCountLabel" Content="0" HorizontalAlignment="Left" Margin="71,163,0,0" VerticalAlignment="Top" Foreground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" Height="28" Width="41"/>
                <Label x:Name="comboLabel"  Content="0" HorizontalAlignment="Left" Margin="71,239,0,0" VerticalAlignment="Top" Foreground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" Height="28" Width="53"/>


                <Label Content="Vibration Intensity" HorizontalAlignment="Left" Margin="125,7,0,0" VerticalAlignment="Top" Foreground="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" Height="19"/>
                <Label Content="Vibration TIme (s)" HorizontalAlignment="Left" Margin="288,7,0,0" VerticalAlignment="Top" Foreground="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" Height="19"/>

                <Slider x:Name="c50slider" HorizontalAlignment="Left" Maximum="20" Margin="125,97,0,0"  VerticalAlignment="Top" Width="120" Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" Value="8"/>
                <Slider x:Name="missSlider" HorizontalAlignment="Left" Maximum="20" Margin="125,129,0,0" VerticalAlignment="Top" Width="120" Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" Value="12"/>
                <Slider x:Name="c100slider" HorizontalAlignment="Left" Maximum="20" Margin="125,65,0,0"  VerticalAlignment="Top" Width="120" Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" Value="1"/>
                <Slider x:Name="c300slider" HorizontalAlignment="Left" Maximum="20" Margin="125,33,0,0"  VerticalAlignment="Top" Width="120" Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" SmallChange="3"/>
                <Slider x:Name="sbSlider" HorizontalAlignment="Left" Maximum="20" Margin="125,161,0,0" VerticalAlignment="Top" Width="120" Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" Value="10"/>

                <ui:NumberBox x:Name="c300time" HorizontalAlignment="Left" Margin="283,33,0,0" Text="0" VerticalAlignment="Top" Width="120" LargeChange="7"/>
                <ui:NumberBox x:Name="c100time" HorizontalAlignment="Left" Margin="283,65,0,0" Text="0.1" VerticalAlignment="Top" Width="120" LargeChange="7"/>
                <ui:NumberBox x:Name="c50time" HorizontalAlignment="Left" Margin="283,97,0,0" Text="0.5" VerticalAlignment="Top" Width="120" LargeChange="7"/>
                <ui:NumberBox x:Name="missTime" HorizontalAlignment="Left" Margin="283,129,0,0" Text="0.5" VerticalAlignment="Top" Width="120" LargeChange="7"/>
                <ui:NumberBox x:Name="sbTime" HorizontalAlignment="Left" Margin="283,161,0,0" Text="0.5" VerticalAlignment="Top" Width="120" LargeChange="7"/>
                <Label Content="Health Mode:" HorizontalAlignment="Left" Margin="11,272,0,0" VerticalAlignment="Top" Foreground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" Height="28" Width="107"/>

                <CheckBox x:Name="healthModeCb" Margin="125,270,0,0" VerticalAlignment="Top" Foreground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" Background="White"/>
                <Label Content="Current Health:" HorizontalAlignment="Left" Margin="10,305,0,0" VerticalAlignment="Top" Foreground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" Height="28" Width="107"/>
                <ProgressBar x:Name="currentHealthBar" HorizontalAlignment="Left" Height="10" Margin="125,309,0,0" VerticalAlignment="Top" Width="120"/>
                <CheckBox x:Name="comboModeCb" Margin="234,233,0,0" VerticalAlignment="Top" Foreground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" Background="White" IsChecked="True"/>
                <Label Content="Combo Multiplier:" HorizontalAlignment="Left" Margin="114,239,0,0" VerticalAlignment="Top" Foreground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" Height="28" Width="121" RenderTransformOrigin="0.5,0.5">
                    <Label.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform AngleY="-0.347"/>
                            <RotateTransform/>
                            <TranslateTransform Y="-0.161"/>
                        </TransformGroup>
                    </Label.RenderTransform>
                </Label>
                <Label Content="Pleasure Mode:" HorizontalAlignment="Left" Margin="11,333,0,0" VerticalAlignment="Top" Foreground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" Height="28" Width="107"/>
                <CheckBox x:Name="pleasureModeCb" Margin="125,331,0,0" VerticalAlignment="Top" Foreground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" Background="White"/>
            </Grid>
        </GroupBox>
        <GroupBox Header="Song Info" Grid.Row="1" Margin="32,10,700,577" Foreground="White" Background="#7F000000">
            <Grid Height="66" Margin="10,0,-10,0">
                <Label x:Name="SongNameLabel" Content="SongName" HorizontalAlignment="Left" Margin="37,0,0,0" VerticalAlignment="Top" Foreground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" />
                <Label x:Name="StatusLabel" Content="Status" HorizontalAlignment="Left" Margin="37,24,0,0" VerticalAlignment="Top" Foreground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" />
            </Grid>
        </GroupBox>
        <Label x:Name="osuConnectionLabel" Content="Connected to osu!" Foreground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" HorizontalAlignment="Left" Margin="1045,659,0,0" Grid.Row="1" VerticalAlignment="Top"/>
        <Label x:Name="intifaceConnectionLabel" Content="Connected to Intiface!" Foreground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" HorizontalAlignment="Left" Margin="1045,683,0,0" Grid.Row="1" VerticalAlignment="Top" Visibility="Hidden"/>

        <GroupBox Header="Toy" Grid.Row="1" Margin="32,189,700,70" Foreground="White" Background="#7F000000">
            <Grid>
                <ListView x:Name="vibrationListView" Foreground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" Margin="28,137,28,10" IsTextSearchEnabled="False" Focusable="False" IsHitTestVisible="False">
                    <ListView.Resources>
                        <Style TargetType="GridViewColumnHeader">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </Style>
                    </ListView.Resources>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn/>
                        </GridView>
                    </ListView.View>
                </ListView>
                <Label x:Name="toyConnectionLabel" Content="" Foreground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" HorizontalAlignment="Left" Margin="28,10,0,0" VerticalAlignment="Top" Width="198" Height="26"/>
                <Label Content="Vibration:" HorizontalAlignment="Left" Margin="28,41,0,0" VerticalAlignment="Top" Foreground="White"/>
                <Label x:Name="currentVibrationLabel" Content="Label" HorizontalAlignment="Left" Margin="93,41,0,0" VerticalAlignment="Top" Width="347" Foreground="White"/>
                <ProgressBar x:Name="currentVibrationTimePb" HorizontalAlignment="Left" Height="29" Margin="93,79,0,0" VerticalAlignment="Top" Width="347"/>
                <ProgressBar x:Name="currentVibrationStrengthPb" HorizontalAlignment="Left" Height="29" Margin="93,108,0,0" VerticalAlignment="Top" Width="347"/>
                <Label Content="Power:" HorizontalAlignment="Left" Margin="28,104,0,0" VerticalAlignment="Top" Foreground="White"/>
                <Label Content="Time:" HorizontalAlignment="Left"  Margin="28,70,0,0" VerticalAlignment="Top" Foreground="White"/>
            </Grid>
        </GroupBox>
    </Grid>
</Window>
